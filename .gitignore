node_modules/
# Stamped at deploy by .github/workflows/pages.yml — never committed; a local run is "unstamped".
version.json
_site/
# Screenshot artifact written by tools/verify-console.mjs on each headless run.
tools/console-verify.png
# Regenerable third-party corpus cache — tools/corpus-fetch.mjs rebuilds this from
# HuggingFace on demand; ~30MB of licensed third-party data doesn't belong in git history.
data/corpus/raw/
# The contrast half of the audit export (~36MB) — regenerable byte-for-byte from the
# committed data/nav-corpus.jsonl by tools/shape-audit.mjs (the parse is deterministic).
data/shapes-audit-contrast.jsonl
